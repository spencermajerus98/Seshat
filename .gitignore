*.docx
*.doc
*.xlsx
*.xls

# Streamlit secrets / local config overrides
.streamlit/secrets.toml

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/

# ── OS / editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# Allow test fixtures even though *.docx/*.xlsx are ignored above
!tests/fixtures/
!tests/fixtures/**
