# ── Seshat: NEVER commit lab data ──────────────────────────────
# Everything below stays on the local machine only.
data/
inbox/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Imported source documents (your protocols / plans)
*.docx
*.doc
*.xlsx
*.xls

# ── Frontend ───────────────────────────────────────────────────
# node_modules is only needed to *build* the bundle. The built output
# (frontend/dist) IS committed/shipped so the app runs with Python alone.
frontend/node_modules/
frontend/.vite/
*.tsbuildinfo

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/

# ── OS / editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# Allow test fixtures even though *.docx/*.xlsx are ignored above
!tests/fixtures/
!tests/fixtures/**
